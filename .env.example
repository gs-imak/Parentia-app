# Leave empty for mock mode, or add your OpenAI API key for real AI
OPENAI_API_KEY=

# Optional: Change port
PORT=3000

# Shared secret protecting the email webhook (/email/inbound) and the manual
# email-check trigger (/email/check). When set, callers must pass it as
# ?secret=... or an X-Webhook-Secret header. Configure the same value in the
# SendGrid Inbound Parse destination URL. Leave empty to disable the check
# (not recommended in production).
EMAIL_WEBHOOK_SECRET=
